{
  // ===== 网关配置 =====
  "gateway": {
    "port": 8080,
    "host": "0.0.0.0"
  },

  // ===== AI 模型配置 =====
  "model": {
    "provider": "deepseek",
    "name": "deepseek-v4-pro",
    "base_url": "https://api.deepseek.com/v1",
    "temperature": 0.7,
    "max_iterations": 15
  },

  // ===== MiMo 模型配置 =====
  "mimo": {
    "provider": "mimo",
    "model_name": "mimo-v2.5",
    "base_url": "https://api.xiaomimimo.com/v1",
    "pro_model_name": "mimo-v2.5-pro",
    "tts_model_name": "mimo-v2.5-tts-voiceclone"
  },

  // ===== Nudge 引擎配置 =====
  "nudge": {
    "enabled": true,
    "interval": 3600,
    "greeting_threshold": 3600,
    "dnd_start": 23,
    "dnd_end": 7
  },

  // ===== 日志配置 =====
  "logging": {
    "level": "INFO",
    "file_path": "~/.ai-agent/logs/agent.log"
  },

  // ===== 插件开关 =====
  "plugins": {
    "qq_bot": true,
    "web_ui": true,
    "cli_agent": true
  },

  // ===== QQ Bot 配置 =====
  "qq_bot": {
    "is_sandbox": false,
    "max_reply_length": 2000,
    "private_chat": true,
    "group_at_only": true
  },

  // ===== 安全策略 =====
  "security": {
    "dangerous_commands_require_confirm": true,
    "max_output_length": 10000,
    "forbidden_paths": [
      "/etc/shadow",
      "/etc/passwd",
      "~/.ssh/"
    ],
    "log_sensitive_ops": true
  },

  // ===== 工作区路径 =====
  "workspace": {
    "dir": "~/.ai-agent/workspace",
    "credentials_dir": "~/.ai-agent/credentials",
    "memory_file": "MEMORY.md",
    "bootstrap_file": "BOOTSTRAP.md"
  }
}
