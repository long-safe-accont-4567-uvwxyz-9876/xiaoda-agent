# ================================================================
# Nahida Agent 环境变量配置
# 复制此文件为 .env 并填写你的 API 密钥
# cp .env.example .env
# ================================================================

# ── 必填：MiMo API（主 LLM + TTS） ──
# 获取方式：https://xiaomimimo.com → 注册 → 控制台 → API Keys
MIMO_API_KEY=
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_MODEL_NAME=mimo-v2.5
MIMO_PRO_MODEL_NAME=mimo-v2.5-pro
MIMO_TTS_MODEL_NAME=mimo-v2.5-tts-voiceclone

# ── 必填：QQ 机器人 ──
# 获取方式：https://q.qq.com → 创建机器人应用 → 获取 AppID 和 AppSecret
# 注意：你需要自己注册 QQ 机器人，不要使用他人的凭证
QQBOT_APP_ID=
QQBOT_APP_SECRET=
ENABLE_QQ_BOT=true

# ── 必填：主人 QQ OpenID ──
# 用于识别爸爸身份（区分主人与陌生人）
# 获取方式：在 QQ 中向机器人发送 /whoami，将返回的 OpenID 填入此处
MASTER_QQ_OPENID=

# ── 必填：管理员用户 ID ──
# 逗号分隔的用户 OpenID 列表，如: ABCDEFG123,HIJKLMN456
# 在 QQ 中发送消息给机器人后，可从日志中获取你的 OpenID
OWNER_IDS=

# ── 可选：Web UI ──
WEBUI_PORT=8082
WEBUI_HOST=0.0.0.0
# 留空则无需密码登录
WEBUI_PASSWORD=

# ── 可选：Embedding 向量检索 ──
# 推荐使用 SiliconFlow（免费额度），也可用 OpenAI 兼容接口
# 获取方式：https://siliconflow.cn → 注册 → API Keys
EMBED_API_KEY=
EMBED_BASE_URL=https://api.siliconflow.cn/v1
EMBED_MODEL=BAAI/bge-large-zh-v1.5

# ── 可选：Nudge 主动问候引擎 ──
NUDGE_ENABLED=true
NUDGE_USER_OPENID=
NUDGE_GREETING_THRESHOLD=3600
NUDGE_DND_START=23
NUDGE_DND_END=7
NUDGE_TIMEZONE=Asia/Shanghai

# ── 可选：图片上传 ──
# 获取方式：https://api.imgbb.com → 注册 → API Key
IMGBB_API_KEY=

# ── 可选：WolframAlpha 知识计算 ──
# 获取方式：https://products.wolframalpha.com/api/ → 注册 → Get AppID
WOLFRAMALPHA_API_KEY=

# ── 可选：数据目录 ──
# Docker 部署时设为 /data，裸机部署可设为自定义路径
KIOXIA_DATA_DIR=/data

# ── 可选：第三方 API ──
# OpenRouter：https://openrouter.ai → 注册 → API Keys
OPENROUTER_API_KEY=
# SiliconFlow：https://siliconflow.cn → 注册 → API Keys
SILICONFLOW_API_KEY=
# Tavily 搜索：https://tavily.com → 注册 → API Keys
TAVILY_API_KEY=

# ── 可选：Agnes AI（图像/视频生成） ──
# 获取方式：https://agnes-ai.com → 注册 → API Keys
AGNES_API_KEY=
AGNES_BASE_URL=https://apihub.agnes-ai.com/v1
AGNES_TEXT_MODEL=agnes-2.0-flash
AGNES_IMAGE_MODEL=agnes-image-2.1-flash
AGNES_VIDEO_MODEL=agnes-video-v2.0

# ── 可选：GitHub MCP Server ──
# 获取方式：https://github.com/settings/tokens → Generate new token (classic)
# 需要勾选 repo, read:org 权限
GITHUB_PERSONAL_ACCESS_TOKEN=

# ── 可选：硬件加速（仅 RK3588/RK3588S） ──
ENABLE_NPU=false

# ── 可选：DeepSeek API（Legacy，可用 MiMo 替代） ──
# 获取方式：https://platform.deepseek.com → 注册 → API Keys
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
MODEL_NAME=mimo-v2.5
