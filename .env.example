# ── MiMo API ──
MIMO_API_KEY=
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_MODEL_NAME=mimo-v2.5
MIMO_PRO_MODEL_NAME=mimo-v2.5-pro

# ── TTS (MiMo Voice Clone) ──
MIMO_TTS_MODEL_NAME=mimo-v2.5-tts-voiceclone

# ── QQ Bot ──
QQBOT_APP_ID=
QQBOT_APP_SECRET=
ENABLE_QQ_BOT=true

# ── Owner ──
# 逗号分隔的用户ID列表，如: user1,user2
OWNER_IDS=

# ── Web UI ──
WEBUI_PORT=8080
WEBUI_HOST=0.0.0.0
WEBUI_PASSWORD=

# ── Embedding ──
EMBED_API_KEY=
EMBED_BASE_URL=
EMBED_MODEL=

# ── Nudge Engine ──
NUDGE_ENABLED=true
NUDGE_USER_OPENID=
NUDGE_GREETING_THRESHOLD=3600
NUDGE_DND_START=23
NUDGE_DND_END=7
NUDGE_TIMEZONE=Asia/Shanghai

# ── Image Upload ──
IMGBB_API_KEY=

# ── WolframAlpha ──
WOLFRAMALPHA_API_KEY=

# ── Data Directory ──
# Docker 部署时设为 /data，裸机部署可设为自定义路径
KIOXIA_DATA_DIR=/data

# ── Optional APIs ──
OPENROUTER_API_KEY=
SILICONFLOW_API_KEY=
TAVILY_API_KEY=

# ── Agnes AI (图像/视频生成) ──
AGNES_API_KEY=
AGNES_BASE_URL=https://apihub.agnes-ai.com/v1
AGNES_TEXT_MODEL=agnes-2.0-flash
AGNES_IMAGE_MODEL=agnes-image-2.1-flash
AGNES_VIDEO_MODEL=agnes-video-v2.0

# ── GitHub MCP Server ──
GITHUB_PERSONAL_ACCESS_TOKEN=

# ── Hardware ──
ENABLE_NPU=false

# ── Legacy ──
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
MODEL_NAME=mimo-v2.5
